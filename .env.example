# =============================================================================
# HYDRA — environment configuration template
# =============================================================================
#
# Copy this file to .env and fill in the values that apply to your
# deployment. Keys without uncommented values fall back to the defaults
# declared in src/hydra/config.py and docker-compose.yml.
#
# .env is gitignored; .env.example IS checked in. Do not put real secrets
# into .env.example.
#
# Conventions:
#   * HYDRA_* prefix         -> consumed by src/hydra/config.HydraSettings
#                               (nested via double underscore, e.g.
#                               HYDRA_DATABASE__POSTGRES_DSN)
#   * POSTGRES_/NEO4J_/MINIO_ -> consumed by the official container
#                               images in docker-compose.yml
#   * GRAFANA_ADMIN_PASSWORD -> substituted into docker-compose.yml via
#                               the ${GRAFANA_ADMIN_PASSWORD:-admin} expansion
#
# To use this with docker compose:
#   1. Copy:    cp .env.example .env
#   2. Fill in: python scripts/configure.py
#   3. Launch:  docker compose up -d
#
# To use it with a local (non-Docker) Python run:
#   1. python -m venv .venv && . .venv/bin/activate   (or .venv\Scripts\activate on Windows)
#   2. pip install -e ".[dev]"
#   3. set -a; source .env; set +a                    (bash)
#      OR in PowerShell:
#      Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($Matches[1], $Matches[2]) } }
# =============================================================================


# -----------------------------------------------------------------------------
# Container image usernames & passwords (consumed by docker-compose.yml)
# -----------------------------------------------------------------------------
# These are read BY THE CONTAINERS themselves at startup (postgres, neo4j,
# minio). Changes here must be reflected in the HYDRA_DATABASE__* DSN values
# below so HYDRA can connect.

POSTGRES_DB=hydra
POSTGRES_USER=hydra
POSTGRES_PASSWORD=hydra

NEO4J_USER=neo4j
NEO4J_PASSWORD=hydrapass

MINIO_ROOT_USER=hydra
MINIO_ROOT_PASSWORD=hydrapass


# -----------------------------------------------------------------------------
# Grafana admin (read by docker-compose.yml via ${GRAFANA_ADMIN_PASSWORD:-admin})
# -----------------------------------------------------------------------------
# If unset, compose falls back to "admin". Override in production.

GRAFANA_ADMIN_PASSWORD=admin


# -----------------------------------------------------------------------------
# HYDRA storage DSNs / URLs (HydraSettings.database)
# -----------------------------------------------------------------------------
# When running HYDRA inside docker-compose, the service hostnames below
# ("postgres", "influxdb", etc.) resolve on the hydra-net bridge network.
# When running HYDRA directly on the host, replace with "localhost".

HYDRA_DATABASE__POSTGRES_DSN=postgresql+asyncpg://hydra:hydra@postgres:5432/hydra
HYDRA_DATABASE__INFLUXDB_URL=http://influxdb:8086
HYDRA_DATABASE__INFLUXDB_ORG=hydra
HYDRA_DATABASE__INFLUXDB_BUCKET=hydra-timeseries
HYDRA_DATABASE__ELASTICSEARCH_URL=http://elasticsearch:9200
HYDRA_DATABASE__NEO4J_URI=bolt://neo4j:7687
HYDRA_DATABASE__MINIO_URL=http://minio:9000
HYDRA_DATABASE__REDIS_URL=redis://redis:6379/0

# Pool sizing (defaults usually fine)
# HYDRA_DATABASE__PG_POOL_MIN=5
# HYDRA_DATABASE__PG_POOL_MAX=20
# HYDRA_DATABASE__REDIS_POOL_MAX=20


# -----------------------------------------------------------------------------
# API layer (HydraSettings.api)
# -----------------------------------------------------------------------------

HYDRA_API__HOST=0.0.0.0
HYDRA_API__PORT=8000
HYDRA_API__WORKERS=4

# CORS — JSON list. "*" allows any origin (dev only). Use a JSON list for
# production: '["https://hydra.example.com","https://admin.example.com"]'
HYDRA_API__CORS_ORIGINS=["*"]

# Rate limiting — requests per minute per (api_key, tier)
# HYDRA_API__RATE_LIMIT_ENABLED=true
# HYDRA_API__RATE_LIMIT_READ=100
# HYDRA_API__RATE_LIMIT_SEARCH=30
# HYDRA_API__RATE_LIMIT_WRITE=10

# Job lifecycle
# HYDRA_API__JOB_TTL_SECONDS=3600

# Pagination bounds (enforced by PaginationParams validation)
# HYDRA_API__DEFAULT_PAGE_SIZE=50
# HYDRA_API__MAX_PAGE_SIZE=500


# -----------------------------------------------------------------------------
# Scheduler (HydraSettings.scheduler)
# -----------------------------------------------------------------------------

# HYDRA_SCHEDULER__AIRFLOW_HOME=/opt/airflow
# HYDRA_SCHEDULER__RETRY_COUNT=3
# HYDRA_SCHEDULER__RETRY_DELAY_SECONDS=60
# HYDRA_SCHEDULER__GLOBAL_RATE_LIMIT=100
# HYDRA_SCHEDULER__GLOBAL_CONCURRENCY_LIMIT=10

# Backpressure
# HYDRA_SCHEDULER__BACKPRESSURE_SOFT_LIMIT=1000
# HYDRA_SCHEDULER__BACKPRESSURE_HARD_LIMIT=5000

# Dead-stream detection
# HYDRA_SCHEDULER__DEAD_STREAM_THRESHOLD=5


# -----------------------------------------------------------------------------
# Correlation (HydraSettings.correlation)
# -----------------------------------------------------------------------------

# HYDRA_CORRELATION__GEO_TEMPORAL_RADIUS_KM=50.0
# HYDRA_CORRELATION__GEO_TEMPORAL_WINDOW_S=3600.0
# HYDRA_CORRELATION__ENTITY_NAME_SIMILARITY_THRESHOLD=0.85
# HYDRA_CORRELATION__THREAT_CONVERGENCE_MIN_TIERS=3
# HYDRA_CORRELATION__CONFIDENCE_THRESHOLD_DEFAULT=0.5


# -----------------------------------------------------------------------------
# Analysis / intelligence products (HydraSettings.analysis)
# -----------------------------------------------------------------------------

# HYDRA_ANALYSIS__SITREP_MAX_EVENTS_PER_TIER=20
# HYDRA_ANALYSIS__DOSSIER_NETWORK_DEPTH=2
# HYDRA_ANALYSIS__DOSSIER_MAX_NETWORK_NODES=50
# HYDRA_ANALYSIS__TIMELINE_MAX_EVENTS=500
# HYDRA_ANALYSIS__DEFAULT_MAX_RECORDS=10000


# -----------------------------------------------------------------------------
# Monitoring / observability (HydraSettings.monitoring)
# -----------------------------------------------------------------------------

# Collector intervals (seconds)
# HYDRA_MONITORING__SCHEDULER_COLLECTOR_INTERVAL=30
# HYDRA_MONITORING__STORAGE_COLLECTOR_INTERVAL=30
# HYDRA_MONITORING__API_COLLECTOR_INTERVAL=60
# HYDRA_MONITORING__PIPELINE_COLLECTOR_INTERVAL=300

# Anomaly detection
# HYDRA_MONITORING__ANOMALY_DETECTION_INTERVAL=300
# HYDRA_MONITORING__ANOMALY_ZSCORE_THRESHOLD=3.0
# HYDRA_MONITORING__ANOMALY_EWMA_SPAN=24
# HYDRA_MONITORING__ANOMALY_WINDOW_SIZE=288

# Capacity thresholds (bytes). Defaults: 100GB PG, 50GB ES, 50GB Influx, 500GB MinIO.
# HYDRA_MONITORING__CAPACITY_PG_THRESHOLD_BYTES=107374182400
# HYDRA_MONITORING__CAPACITY_ES_THRESHOLD_BYTES=53687091200
# HYDRA_MONITORING__CAPACITY_INFLUX_THRESHOLD_BYTES=53687091200
# HYDRA_MONITORING__CAPACITY_MINIO_THRESHOLD_BYTES=536870912000
# HYDRA_MONITORING__CAPACITY_HISTORY_RETENTION_DAYS=90

# SLO targets (0.0–1.0). Defaults: 99.5%, 99.9%, 99%, 99%, 98%, 99.9%.
# HYDRA_MONITORING__SLO_ADAPTER_SUCCESS_TARGET=0.995
# HYDRA_MONITORING__SLO_API_AVAILABILITY_TARGET=0.999
# HYDRA_MONITORING__SLO_API_LATENCY_P95_TARGET=0.99
# HYDRA_MONITORING__SLO_API_LATENCY_THRESHOLD_SECONDS=2.0
# HYDRA_MONITORING__SLO_PRODUCT_GENERATION_TARGET=0.99
# HYDRA_MONITORING__SLO_INGESTION_FRESHNESS_TARGET=0.98
# HYDRA_MONITORING__SLO_STORAGE_AVAILABILITY_TARGET=0.999

# Logging
HYDRA_MONITORING__LOG_FORMAT=json
HYDRA_MONITORING__LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Alert routing — Alertmanager webhooks (referenced by alertmanager/alertmanager.yml)
# -----------------------------------------------------------------------------
# Alertmanager is a SEPARATE container. It reads its config at startup and
# does NOT consume env vars directly — the values below are substituted
# into alertmanager.yml by scripts/configure.py. If you change these, run
# scripts/configure.py again (or edit alertmanager.yml directly).

# Slack webhook URL. Create at https://api.slack.com/apps > Incoming Webhooks.
SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 routing key. Create a service integration in the
# PagerDuty UI. If blank, the pagerduty-critical receiver will fail on
# delivery (but alerts still route to slack-critical).
PAGERDUTY_ROUTING_KEY=


# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------

# HYDRA_HTTP_TIMEOUT_SECONDS=30
# HYDRA_DATA_DIR=data
# HYDRA_STREAM_REGISTRY_PATH=src/hydra/registry/stream_registry.yaml
# HYDRA_CREDENTIAL_STORE_PATH=config/credentials.yaml
