{
  "uid": "hydra-api",
  "title": "HYDRA \u2014 API",
  "tags": [
    "hydra"
  ],
  "schemaVersion": 36,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "total req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "description": "Total HTTP request rate from prometheus_fastapi_instrumentator."
    },
    {
      "id": 2,
      "title": "Request Duration P95 (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra:api_request_duration_p95_5m",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "95th percentile API request latency (recording rule)."
    },
    {
      "id": 3,
      "title": "Request Duration P50 (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra:api_request_duration_p50_5m",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "Median API request latency (recording rule)."
    },
    {
      "id": 4,
      "title": "Error Rate 5xx (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra:api_error_rate_5m",
          "legendFormat": "5xx share"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "description": "Share of HTTP 5xx responses among all responses (recording rule)."
    },
    {
      "id": 5,
      "title": "Status Code Distribution (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum by (status) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "description": "Per-status-code HTTP response rate."
    },
    {
      "id": 6,
      "title": "In-Flight Requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum(http_requests_in_progress)",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Concurrent HTTP requests in flight (from instrumentator)."
    },
    {
      "id": 7,
      "title": "Rate Limit Hits (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum by (tier) (rate(hydra_api_rate_limit_hits_total[5m]))",
          "legendFormat": "{{tier}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Rate-limit 429 response rate, grouped by tier."
    },
    {
      "id": 8,
      "title": "Active API Keys",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_api_active_keys",
          "legendFormat": "active keys"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Count of enabled, non-expired API keys.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 9,
      "title": "Job Status Distribution",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_api_job_status",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Current async job counts by status (pending, running, completed, failed)."
    },
    {
      "id": 10,
      "title": "Job Duration P95 (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, job_type) (rate(hydra_api_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "95th percentile async job duration, per job type."
    },
    {
      "id": 11,
      "title": "API Errors (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum by (error_code, endpoint) (rate(hydra_api_error_total[5m]))",
          "legendFormat": "{{error_code}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Application-level API errors per second, grouped by error code and endpoint."
    }
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  }
}
