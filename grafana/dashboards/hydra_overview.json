{
  "uid": "hydra-overview",
  "title": "HYDRA \u2014 Overview",
  "tags": [
    "hydra"
  ],
  "schemaVersion": 36,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "title": "System Health (Scheduler)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_scheduler_health_status",
          "legendFormat": "scheduler"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "UNREACHABLE",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "DEGRADED",
                  "color": "orange",
                  "index": 1
                },
                "2": {
                  "text": "OK",
                  "color": "green",
                  "index": 2
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Scheduler health aggregator \u2014 0 UNREACHABLE, 1 DEGRADED, 2 OK.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Active Adapters",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_scheduler_active_adapters",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Total adapter executions in flight across all cadences.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Dead Streams",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_adapter_dead_streams",
          "legendFormat": "dead"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Streams exceeding the consecutive-failure threshold.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Ingestion Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "sum(hydra:ingestion_rate_5m)",
          "legendFormat": "records/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Records stored per second (5m rolling recording rule)."
    },
    {
      "id": 5,
      "title": "Adapter Success Rate (per stream, 5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra:adapter_success_rate_5m",
          "legendFormat": "{{stream_id}} ({{tier}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "description": "5-minute success rate per stream from the recording rule."
    },
    {
      "id": 6,
      "title": "Storage Health Matrix",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_storage_health_status",
          "legendFormat": "{{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "UNREACHABLE",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "DEGRADED",
                  "color": "orange",
                  "index": 1
                },
                "2": {
                  "text": "OK",
                  "color": "green",
                  "index": 2
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          },
          "min": 0,
          "max": 2
        },
        "overrides": []
      },
      "description": "Per-engine health: 0 UNREACHABLE, 1 DEGRADED, 2 OK."
    },
    {
      "id": 7,
      "title": "Backpressure State",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_backpressure_state",
          "legendFormat": "{{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLEAR",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "THROTTLED",
                  "color": "orange",
                  "index": 1
                },
                "2": {
                  "text": "BLOCKED",
                  "color": "red",
                  "index": 2
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "min": 0,
          "max": 2
        },
        "overrides": []
      },
      "description": "0 CLEAR, 1 THROTTLED, 2 BLOCKED."
    },
    {
      "id": 8,
      "title": "WAQ Depth",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_storage_waq_depth",
          "legendFormat": "{{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Write-ahead queue depth per engine."
    },
    {
      "id": 9,
      "title": "DLQ Depth",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_storage_dlq_depth",
          "legendFormat": "{{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Dead-letter queue depth per engine."
    },
    {
      "id": 10,
      "title": "SLO Error Budget Remaining",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_slo_error_budget_remaining",
          "legendFormat": "{{slo_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m"
        },
        "overrides": []
      },
      "description": "Remaining error budget (minutes) per SLO. Negative = breached."
    },
    {
      "id": 11,
      "title": "Capacity Forecast (days to threshold)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hydra-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "hydra-prometheus"
          },
          "expr": "hydra_capacity_days_to_threshold",
          "legendFormat": "{{engine}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d"
        },
        "overrides": []
      },
      "description": "Projected days until storage threshold per engine. -1 = no exhaustion projected."
    }
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  }
}
