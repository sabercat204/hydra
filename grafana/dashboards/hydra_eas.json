{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source backing HYDRA platform metrics.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HYDRA Phase 13 — Extended Access Services. Panels per Design §11.4 covering every capability exposed by the EAS module: exposure events, screenshot captures, CVE ingestion, lookup cache, cost quotas, observatory runs, trends, and maps.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "iteration": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Capability 1 — Asset Exposure Monitoring",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Exposure events per tenant (5m rate)",
      "description": "Rate of asset_exposures rows persisted per tenant per asset_type per tier per severity (R3.4).",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum by (tenant_id, severity) (rate(hydra_eas_exposure_events_total[5m]))",
          "legendFormat": "{{tenant_id}} / {{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "min": 0},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Exposure buffer overflow (counter)",
      "description": "Rising signal indicates PG backpressure is dropping exposures in memory (Design §6.1).",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "sum(increase(hydra_eas_exposure_buffer_overflow_total[1h]))",
          "legendFormat": "1h drops",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 1},
            {"color": "red", "value": 100}
          ]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ASN lookup failures (counter)",
      "description": "Rising signal means the pyasn dataset refresh DAG is failing.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "targets": [
        {
          "expr": "increase(hydra_eas_asn_lookup_failure_total[24h])",
          "legendFormat": "24h failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "row",
      "title": "Capability 2 — Screenshot Intelligence",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 200
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Screenshot capture success rate",
      "description": "success / (success + failed) over 15m. Alert ``HydraEASScreenshotFailureRate`` fires when failure > 30%.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "rate(hydra_eas_screenshot_captures_total{status=\"success\"}[15m]) / (rate(hydra_eas_screenshot_captures_total{status=\"success\"}[15m]) + rate(hydra_eas_screenshot_captures_total{status=\"failed\"}[15m]))",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.7},
            {"color": "green", "value": 0.95}
          ]}
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PNG bytes uploaded to MinIO (5m rate)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "rate(hydra_eas_screenshot_bytes_total[5m])",
          "legendFormat": "bytes/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "row",
      "title": "Capability 3 — CVE & Exploit Enrichment",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 300
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CVE record growth per source (5m rate)",
      "description": "hydra_eas_cve_records_total per source (R9.7): nvd / epss / kev / exploitdb / metasploit.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 19},
      "targets": [
        {
          "expr": "rate(hydra_eas_cve_records_total[5m])",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "row",
      "title": "Capability 4 — Geospatial Maps",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 400
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Maps tiles returned per response (p95)",
      "description": "histogram_quantile of hydra_eas_maps_tiles_returned per aggregation strategy.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (strategy, le) (rate(hydra_eas_maps_tiles_returned_bucket[5m])))",
          "legendFormat": "p95 / {{strategy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "row",
      "title": "Capability 5 — Trends",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "id": 500
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Trends response size (p95) per bucket",
      "description": "histogram_quantile of hydra_eas_trends_window_bytes per bucket literal.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 37},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (bucket, le) (rate(hydra_eas_trends_window_bytes_bucket[5m])))",
          "legendFormat": "p95 / {{bucket}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "row",
      "title": "Capability 6 — Fast Indicator Lookup",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
      "id": 600
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Lookup cache hit ratio",
      "description": "hits / (hits + misses) per indicator class. Alert ``HydraEASLookupCacheHitRateLow`` fires when <50% for 30m.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 46},
      "targets": [
        {
          "expr": "sum by (indicator_class) (rate(hydra_eas_lookup_cache_hits_total[15m])) / (sum by (indicator_class) (rate(hydra_eas_lookup_cache_hits_total[15m])) + sum by (indicator_class) (rate(hydra_eas_lookup_cache_misses_total[15m])))",
          "legendFormat": "hit ratio / {{indicator_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Lookup cache size (keys)",
      "description": "Current count of hydra:eas:lookup:* keys in the cache DB.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 46},
      "targets": [
        {
          "expr": "hydra_eas_lookup_cache_size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "max": 100000,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 80000},
            {"color": "red", "value": 95000}
          ]}
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Lookup p95 latency fast ratio (recording rule)",
      "description": "5-minute rolling fraction of /lookup requests under the p95 latency target (R23.4).",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 46},
      "targets": [
        {
          "expr": "hydra:eas_lookup_fast_ratio_5m",
          "legendFormat": "fast ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1}
      }
    },
    {
      "type": "row",
      "title": "Capability 7 — Exposure Observatory",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 54},
      "id": 700
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Observatory DAG runs",
      "description": "Counter of runs per status (success / failed). Alert ``HydraEASObservatoryStale`` fires when no successful run in 48h.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 55},
      "targets": [
        {
          "expr": "increase(hydra_eas_observatory_runs_total[1d])",
          "legendFormat": "1d / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Seconds since last observatory run",
      "description": "time() - hydra_eas_observatory_last_run_timestamp_seconds. Alert fires at >172800 (48h).",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 55},
      "targets": [
        {
          "expr": "time() - hydra_eas_observatory_last_run_timestamp_seconds",
          "legendFormat": "staleness",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 86400},
            {"color": "red", "value": 172800}
          ]}
        }
      }
    },
    {
      "type": "row",
      "title": "Cross-cutting — Cost Quotas",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 63},
      "id": 800
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Quota usage ratio per tenant and quota",
      "description": "hydra_eas_quota_usage_ratio — R22.4. Alert ``HydraEASQuotaNearExhaustion`` fires at >0.9.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 64},
      "targets": [
        {
          "expr": "hydra_eas_quota_usage_ratio",
          "legendFormat": "{{tenant_id}} / {{quota_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 0.8},
            {"color": "red", "value": 0.9}
          ]}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["hydra", "eas", "phase-13"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "",
  "title": "HYDRA — Extended Access Services",
  "uid": "hydra-eas",
  "version": 1,
  "weekStart": ""
}
